# Prevent automatic execution of lifecycle scripts (postinstall, install, preinstall)
# during npm install. Protects against malicious supply-chain postinstall payloads.
# CWE-494 / security-mcp finding DEP_IGNORE_SCRIPTS_MISSING.
ignore-scripts=true

# Pin the @modelcontextprotocol scope to the public npm registry so a malicious
# higher-versioned package cannot be substituted from another registry.
# CWE-1357 (dependency confusion) / security-mcp finding DEPENDENCY_CONFUSION_RISK.
@modelcontextprotocol:registry=https://registry.npmjs.org/
