{
  "Resources": {
    "PublicBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "AccessControl": "PublicRead",
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": false,
          "BlockPublicPolicy": false,
          "IgnorePublicAcls": false,
          "RestrictPublicBuckets": false
        },
        "BucketEncryption": {}
      }
    },
    "OpenSg": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "SecurityGroupIngress": [
          { "IpProtocol": "tcp", "FromPort": 22, "ToPort": 22, "CidrIp": "0.0.0.0/0" },
          { "IpProtocol": "tcp", "FromPort": 443, "ToPort": 443, "CidrIpv6": "::/0" }
        ]
      }
    },
    "PublicDb": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "PubliclyAccessible": true,
        "StorageEncrypted": false,
        "MasterUserPassword": "Hunter2InlinePass",
        "Encrypted": false,
        "SSEEnabled": false
      }
    },
    "AdminPolicy": {
      "Type": "AWS::IAM::Policy",
      "Properties": {
        "PolicyDocument": {
          "Statement": [
            { "Effect": "Allow", "Action": "iam:PassRole", "Resource": "*" },
            { "Effect": "Allow", "Action": "iam:*", "Resource": "*" }
          ]
        }
      }
    },
    "StaticKey": {
      "Type": "AWS::IAM::AccessKey",
      "Properties": { "UserName": "svc-user" }
    },
    "PublicFn": {
      "Type": "AWS::Lambda::Url",
      "Properties": { "AuthType": "NONE" }
    },
    "OpenTopic": {
      "Type": "AWS::SNS::TopicPolicy",
      "Properties": {
        "PolicyDocument": {
          "Statement": [ { "Effect": "Allow", "Principal": "*", "Action": "sns:Publish" } ]
        }
      }
    },
    "Trail": {
      "Type": "AWS::CloudTrail::Trail",
      "Properties": {
        "IsMultiRegionTrail": false,
        "EnableLogFileValidation": false
      }
    },
    "Nested": {
      "Type": "AWS::CloudFormation::Stack",
      "Properties": { "TemplateURL": "http://example.com/template.yaml" }
    },
    "InlineSecret": {
      "Type": "AWS::SecretsManager::Secret",
      "Properties": { "SecretString": "PlaintextSecretValue1", "Token": "tok_abc123def456" }
    },
    "Box": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "MetadataOptions": { "HttpTokens": "optional" }
      }
    }
  },
  "Parameters": {
    "DbPassword": { "Type": "String" },
    "ApiToken": { "Type": "String" },
    "MasterSecret": { "Type": "String" }
  }
}
